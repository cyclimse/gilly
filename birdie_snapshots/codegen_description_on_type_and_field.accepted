---
version: 1.5.4
title: codegen description on type and field
file: ./test/gilly/internal/codegen_test.gleam
test_name: description_on_type_and_field_test
---
import gleam/dynamic/decode

/// A user account.
pub type User {
  User(
    /// The user's display name.
    name: String,
  )
}

pub fn user_decoder() -> decode.Decoder(User) {
  use name <- decode.field("name", decode.string)
  decode.success(User(name:))
}

