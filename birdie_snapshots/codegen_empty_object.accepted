import gleam/dynamic/decode
import gleam/json

pub type EmptyRecord {
  EmptyRecord
}

pub fn empty_record_decoder() -> decode.Decoder(EmptyRecord) {
  decode.success(EmptyRecord)
}

pub fn empty_record_to_json(value: EmptyRecord) -> json.Json {
  json.object([])
}

pub fn new_empty_record() -> EmptyRecord {
  EmptyRecord
}

