    #("protocol", json.nullable(value.protocol, create_container_request_protocol_to_json)),
    #("registry_image", json.nullable(value.registry_image, json.string)),
    #("sandbox", json.nullable(value.sandbox, create_container_request_sandbox_to_json)),
    #("scaling_option", json.nullable(value.scaling_option, fn(v) { v })),
    #("secret_environment_variables", json.nullable(value.secret_environment_variables, json.array(_, scaleway_containers_v1beta1_secret_to_json))),
    #("tags", json.nullable(value.tags, json.array(_, json.string))),
    #("timeout", json.nullable(value.timeout, json.string)),
  ])
