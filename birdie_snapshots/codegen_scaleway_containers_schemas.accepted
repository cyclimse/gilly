  use value <- decode.then(decode.string)
  case value {
    "unknown_input_type" -> decode.success(UnknownInputType)
    "sqs" -> decode.success(Sqs)
    "scw_sqs" -> decode.success(ScwSqs)
    "nats" -> decode.success(Nats)
    "scw_nats" -> decode.success(ScwNats)
    _ -> decode.failure(UnknownInputType, "UnknownInputTypeSqsScwSqsNatsScwNats")
  }
}

