pub type UnknownHttpOptionEnabledRedirected {
  UnknownHttpOption
  Enabled
  Redirected
}

pub fn unknown_http_option_enabled_redirected_decoder() -> decode.Decoder(UnknownHttpOptionEnabledRedirected) {
  use value <- decode.then(decode.string)
  case value {
    "unknown_http_option" -> decode.success(UnknownHttpOption)
    "enabled" -> decode.success(Enabled)
    "redirected" -> decode.success(Redirected)
    _ -> decode.failure(UnknownHttpOption, "UnknownHttpOptionEnabledRedirected")
  }
}

pub type UnknownInputTypeSqsScwSqsNatsScwNats {
