{
    "openapi": "3.0.4",
    "info": {
        "title": "Hello World API",
        "version": "1.0.0"
    },
    "paths": {
        "/hello": {
            "get": {
                "operationId": "sayHello",
                "summary": "Say hello.",
                "responses": {
                    "200": {
                        "description": "Successful response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "message": {
                                            "type": "string"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}